{
  "name": "@numidev/react-native-spotlight-tour",
  "description": "React Native library to implement a highly customizable app tour feature with an awesome spotlight effect. Fork of https://github.com/stackbuilders/react-native-spotlight-tour, refactored to use `@shopify/react-native-skia` + `react-native-reanimated` to hugely increase spotlight animations performances.",
  "repository": "git@github.com:Numidev-dev/react-native-spotlight-tour.git",
  "author": "Numidev <contact@numidev.fr> (https://github.com/Numidev-dev)",
  "license": "MIT",
  "workspaces": [
    "example/",
    "package/"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "android": "yarn workspace example android",
    "build": "turbo build",
    "check": "NODE_OPTIONS=\"--no-experimental-detect-module\" turbo check && yarn lint",
    "compile": "turbo compile",
    "docs": "yarn workspace react-native-spotlight-tour docs",
    "ios": "yarn workspace example ios",
    "lint": "eslint .",
    "release": "turbo release --concurrency=1",
    "start": "turbo start",
    "start:reset": "turbo start:reset",
    "test": "NODE_OPTIONS=\"--no-experimental-detect-module\" turbo test",
    "test:ci": "turbo test"
  },
  "packageManager": "yarn@4.9.1",
  "devDependencies": {
    "@eslint/js": "^9.29.0",
    "@stylistic/eslint-plugin": "^4.4.1",
    "all-contributors-cli": "^6.26.1",
    "eslint": "^9.29.0",
    "eslint-import-resolver-typescript": "^4.4.3",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-jsdoc": "^51.0.3",
    "eslint-plugin-perfectionist": "^4.14.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-sonarjs": "^3.0.3",
    "globals": "^16.2.0",
    "turbo": "^2.5.4",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.34.1"
  },
  "dependencies": {
    "@shopify/react-native-skia": "^2.6.2",
    "react-native-reanimated": "^4.3.0"
  }
}
